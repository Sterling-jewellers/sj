# ─────────────────────────────────────────────────────────────────────────────
# Sterling Jewellers — Client environment variables
# Copy this file to .env.local for local development.
# On Netlify, add these in Site Settings → Environment Variables.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL
# Development: http://localhost:5001/api
# Production:  https://sterling-jewellers-api.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Stripe publishable key (safe to expose — it's public by design)
# Get from https://dashboard.stripe.com/apikeys
# Use pk_test_* for dev, pk_live_* for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXX

# Your site's public URL (used for SEO: sitemap, canonical tags, OG URLs)
# Development: http://localhost:3000
# Production:  https://sterlingjewellers.co.uk
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth (if using social login)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_random_32_char_string

# Google OAuth (optional — only if using Google login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
