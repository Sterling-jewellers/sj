# ─────────────────────────────────────────────────────────────────────────────
# Sterling Jewellers — Server environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5001
NODE_ENV=development                  # change to "production" on Render

# MongoDB Atlas
# Create a free cluster at https://cloud.mongodb.com
MONGO_URI=mongodb+srv://sterlingjewellerslimited_db_user:UYhgXKbNiltdGlhw@sterling-jewellers.2iz2iul.mongodb.net/?appName=Sterling-Jewellers

# JWT — use a long, random string (min 32 chars)
JWT_SECRET=replace_with_a_random_64_char_string
JWT_EXPIRES_IN=30d

# Client URL (for CORS)
# Development: http://localhost:3000
# Production: https://your-site.netlify.app  (or your custom domain)
CLIENT_URL=http://localhost:3000


# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SendGrid (email) ──────────────────────────────────────────────────────────
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=noreply@sterlingjewellers.co.uk

# ── Nivoda Diamond Supplier ───────────────────────────────────────────────────
# Register at https://app.nivoda.net/register (UK B2B diamond marketplace)
# When set, the /api/diamonds endpoint serves LIVE Nivoda inventory with
# real diamond photographs and Loupe360 videos.
NIVODA_USERNAME=sterlingjewellerslimited@gmail.com
NIVODA_PASSWORD=Puresterling11

# ── Stuller Ring Mounts ───────────────────────────────────────────────────────
# Apply for a trade account at https://www.stuller.com/account/register
# Stuller is the wholesale supplier behind Blue Nile, 77 Diamonds, Abelini.
# Their API gives 50,000+ ring settings with professional multi-angle photos.
STULLER_API_KEY=your_stuller_api_key
STULLER_ACCOUNT_ID=your_stuller_account_id

# ── Currency ──────────────────────────────────────────────────────────────────
# Nivoda prices are USD — set your live GBP/USD rate here
USD_TO_GBP_RATE=0.79
GBPUSD_RATE=0.79
